# create a new linux service account
# args: <account-name> <account-home> <account-id>
new_svc_acc() {
  _NEW_SVC_ACC__name="${1:?name}"
  _NEW_SVC_ACC__home="${2:?home}"
  _NEW_SVC_ACC__id="${3:?id}"

  printf " - Creating a new service account '%s' (UID/GID %s)...
   (with home directory '%s')\n" \
         "${_NEW_SVC_ACC__name}" \
         "${_NEW_SVC_ACC__id}" \
         "${_NEW_SVC_ACC__home}"

  # create & init
  sudo useradd \
       -mU \
       -d "${_NEW_SVC_ACC__home}" \
       -u "${_NEW_SVC_ACC__id}" \
       -c "${SAMAN_ACC_COMMENT_PREFIX} ${_NEW_SVC_ACC__name}" \
       -s "${SHELL:-/bin/sh}" \
       "${_NEW_SVC_ACC__name}" || return 1
  sudo loginctl enable-linger "${_NEW_SVC_ACC__name}" || return 1

  printf "%s\n%s\n" \
         "# for systemd command ('systemctl --user')" \
         "export XDG_RUNTIME_DIR=\"/run/user/\$(id -u)\"" \
    | sudo -u "${_NEW_SVC_ACC__name}" \
           tee "${_NEW_SVC_ACC__home}/.profile.saman" >/dev/null \
    || return 1
  printf "\n\n. \"\$HOME/.profile.saman\"\n" \
    | sudo -u "${_NEW_SVC_ACC__name}" \
           tee -a "${_NEW_SVC_ACC__home}/.profile" \
    | sudo -u "${_NEW_SVC_ACC__name}" \
           tee -a "${_NEW_SVC_ACC__home}/.bashrc" >/dev/null \
    || return 1
  if sudo -u "${_NEW_SVC_ACC__name}" \
          [ -e "${_NEW_SVC_ACC__home}/.bash_profile" ];
  then
  printf "\n\n. \"\$HOME/.profile.saman\"\n" \
    | sudo -u "${_NEW_SVC_ACC__name}" \
           tee -a "${_NEW_SVC_ACC__home}/.bash_profile" \
           >/dev/null || return 1
  fi
  if sudo -u "${_NEW_SVC_ACC__name}" \
          [ -e "${_NEW_SVC_ACC__home}/.zshrc" ];
  then
  printf "\n\n. \"\$HOME/.profile.saman\"\n" \
    | sudo -u "${_NEW_SVC_ACC__name}" \
           tee -a "${_NEW_SVC_ACC__home}/.zshrc" \
           >/dev/null || return 1
  fi
}



# remove an existing linux service account created by this script
# args: <account-name>
rm_svc_acc() {
  _RM_SVC_ACC__name="${1:?name}"

  printf " - Removing an existing service account '%s'...
   (with its home directory)\n" \
         "${_RM_SVC_ACC__name}"

  sudo loginctl disable-linger "${_RM_SVC_ACC__name}" || return 1
  sudo killall -w -u "${_RM_SVC_ACC__name}"
  if command -v sestatus >/dev/null
  then sudo userdel -frZ "${_RM_SVC_ACC__name}" || return 1
  else sudo userdel -fr "${_RM_SVC_ACC__name}" || return 1
  fi
  sudo groupdel -f "${_RM_SVC_ACC__name}" 2>/dev/null || true
}



# create all systemd resource control configs
# args: <uid>
new_acc_rc() {
  _NEW_ACC_RC__uid="${1:?uid}"

  # set all configurable rc configs
  for _NEW_ACC_RC__k in ${SYSTEMD_RC_LIST}
  do
    _NEW_ACC_RC__v="$(get_var_default "${_NEW_ACC_RC__k}")"
    set_rc "${_NEW_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_NEW_ACC_RC__k}__LABEL}\"")" \
           "${_NEW_ACC_RC__v}" \
      || return 1
  done

  # set all accounting rc configs (nothing on stdout)
  for _NEW_ACC_RC__accounting in ${SYSTEMD_RC_ACCOUNTING_LIST}
  do
    set_rc "${_NEW_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_NEW_ACC_RC__accounting}__LABEL}\"")" \
           "true" \
           >/dev/null \
      || return 1
  done

  # set all non-configurable rc configs (nothing on stdout)
  for _NEW_ACC_RC__nonconf in ${SYSTEMD_RC_CONST_LIST}
  do
    _NEW_ACC_RC__nonconf_v="$(get_var_default "${_NEW_ACC_RC__nonconf}")"
    set_rc "${_NEW_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_NEW_ACC_RC__nonconf}__LABEL}\"")" \
           "${_NEW_ACC_RC__nonconf_v}" \
           >/dev/null \
      || return 1
  done

  # reload
  sudo systemctl daemon-reload
}



# set a single systemd resource control config
# args: <uid> <key> [val]
set_acc_rc() {
  _SET_ACC_RC__uid="${1:?uid}"
  _SET_ACC_RC__k="${2:?key}"
  _SET_ACC_RC__v="${3}"

  unset _SET_ACC_RC__is_set
  [ -z ${3+set} ] && _SET_ACC_RC__is_set="true"

  if [ "${_SET_ACC_RC__is_set}" = "true" ]
  then
    set_rc "${_SET_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_SET_ACC_RC__k}__LABEL}\"")" \
           "${_SET_ACC_RC__v}" \
      || return 1
  fi

  # reload
  sudo systemctl daemon-reload
}



# remove all systemd resource control configs
# args: <uid>
rm_acc_rc() {
  _RM_ACC_RC__uid="${1:?uid}"

  # remove all configurable rc configs
  for _RM_ACC_RC__k in ${SYSTEMD_RC_LIST}
  do
    set_rc "${_RM_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_RM_ACC_RC__k}__LABEL}\"")" \
      || return 1
  done

  # remove all non-configurable rc configs (nothing on stdout)
  for _RM_ACC_RC__rest in ${SYSTEMD_RC_ACCOUNTING_LIST} ${SYSTEMD_RC_CONST_LIST}
  do
    set_rc "${_RM_ACC_RC__uid}" \
           "$(eval "printf \"%s\" \"\${${_RM_ACC_RC__rest}__LABEL}\"")" \
           >/dev/null \
      || return 1
  done

  # reload
  sudo systemctl daemon-reload
}



# create a new firewall rule for this account
# args: <service-name>
new_firewall_svc() {
  # args
  _NEW_FIREWALL_SVC__name="${1:?name}"
  shift 2>/dev/null

  _NEW_FIREWALL_SVC__ports="$(get_var_default USER_SOCK_ALLOW)"

  printf " - Creating a new firewalld rule '%s'...
   (with ports: %s)\n" \
         "${_NEW_FIREWALL_SVC__name}" "${_NEW_FIREWALL_SVC__ports}"

  # add firewall service and apply
  sudo firewall-cmd --permanent \
       --new-service="${_NEW_FIREWALL_SVC__name}" \
       >/dev/null || return 1
  sudo firewall-cmd --permanent \
       --service="${_NEW_FIREWALL_SVC__name}" \
       --set-short="SAMAN ports config" \
       >/dev/null || return 1
  sudo firewall-cmd --permanent \
       --service="${_NEW_FIREWALL_SVC__name}" \
       --set-description="SAMAN ports config for ${_NEW_FIREWALL_SVC__name}" \
       >/dev/null || return 1

  for _NEW_FIREWALL_SVC__port in ${_NEW_FIREWALL_SVC__ports}
  do
    sudo firewall-cmd --permanent \
         --service="${_NEW_FIREWALL_SVC__name}" \
         --add-port="${_NEW_FIREWALL_SVC__port}"/tcp >/dev/null || return 1
    sudo firewall-cmd --permanent \
         --service="${_NEW_FIREWALL_SVC__name}" \
         --add-port="${_NEW_FIREWALL_SVC__port}"/udp >/dev/null || return 1
  done

  # enable & reload
  sudo firewall-cmd --permanent \
       --add-service="${_NEW_FIREWALL_SVC__name}" \
       >/dev/null || return 1
  sudo firewall-cmd --reload >/dev/null || return 1
}



# remove an existing firewall rule for this account
# args: <service-name> ...
rm_firewall_svc() {
  _RM_FIREWALL_SVC__name="${1:?name}"
  printf " - Removing an existing firewalld rule '%s'...\n" \
         "${_RM_FIREWALL_SVC__name}"

  # enable & reload
  sudo firewall-cmd --permanent \
       --delete-service="${_RM_FIREWALL_SVC__name}" >/dev/null || return 1
  sudo rm -f "/etc/firewalld/services/${_RM_FIREWALL_SVC__name}.xml.old" \
       >/dev/null 2>/dev/null
  sudo firewall-cmd --reload >/dev/null || return 1
}





