# parse options
# usage e.g.: parse_opts "(binname)" "(shorts)" "(longs)" "${@}" && eval set -- "${PARSE_OPTS__args}" || return 1
# args: <bin-name> <short-opt-list> <long-opt-list> [args...]
parse_opts() {
  unset $(set | grep "^PARSE_OPTS__.*$" | cut -d= -f1) # unset all vars
  _PARSE_OPTS__bin_name="${1:?bin-name}"
  _PARSE_OPTS__short_list="${2?short-opt-list}"
  _PARSE_OPTS__long_list="${3?long-opt-list}"
  shift 3 || return 1

  # parse valid short options
  _PARSE_OPTS__short_list_base="$(printf "%s" "${_PARSE_OPTS__short_list}" \
                                  | sed -n 's/\([^:]::\|[^:]:\|[^:]\)/\1\n/gp')"
  _PARSE_OPTS__short_list_flags="$(printf "%s" "${_PARSE_OPTS__short_list_base}" \
                                  | sed -n 's/^\([^:]\)$/-\1/p')"
  _PARSE_OPTS__short_list_args="$(printf "%s" "${_PARSE_OPTS__short_list_base}" \
                                  | sed -n 's/^\([^:]\):\?:$/-\1/p')"

  # parse valid long options
  _PARSE_OPTS__long_list_base="$(printf "%s" "${_PARSE_OPTS__long_list}" \
                                  | tr ',' '\n')"
  _PARSE_OPTS__long_list_flags="$(printf "%s" "${_PARSE_OPTS__long_list_base}" \
                                  | sed -n 's/^\([^:][^:]*\)$/--\1/p')"
  _PARSE_OPTS__long_list_args="$(printf "%s" "${_PARSE_OPTS__long_list_base}" \
                                  | sed -n 's/^\([^:][^:]*\):\?:$/--\1/p')"

  _PARSE_OPTS__evalargs="$(getopt -n "${_PARSE_OPTS__bin_name}" -o "${_PARSE_OPTS__short_list}" ${_PARSE_OPTS__long_list+--longoptions="${_PARSE_OPTS__long_list}"} -- "${@}")" || return 1
  eval set -- "${_PARSE_OPTS__evalargs:?Failed to parse arguments}" || return 1

  while true
  do
    _PARSE_OPTS__cur_arg="${1}"

    if [ "${_PARSE_OPTS__cur_arg}" = "--" ]
    then
      # export remaining as args
      shift
      for _PARSE_OPTS__arg in "${@}"
      do
	      PARSE_OPTS__args="${PARSE_OPTS__args} $(printf "%s" "${_PARSE_OPTS__arg}" \
                                                | sed "s/'/'\\\''/g; s/^\(.*\)$/'\1'/g;")"
      done
      break


    elif printf "%s" "${_PARSE_OPTS__short_list_flags}" \
        | grep -q -- "${_PARSE_OPTS__cur_arg}" >/dev/null 2>/dev/null
    then
      # short - flag
      eval "PARSE_OPTS__opt$(printf '%s' "${_PARSE_OPTS__cur_arg}" | tr '-' '_')"="\"1\"" || return 1
      shift; continue


    elif printf "%s" "${_PARSE_OPTS__short_list_args}" \
        | grep -q -- "${_PARSE_OPTS__cur_arg}" >/dev/null 2>/dev/null
    then
      # short - arg
      eval "PARSE_OPTS__opt$(printf '%s' "${_PARSE_OPTS__cur_arg}" | tr '-' '_')"="\"${2?No argument passed for the option "${_PARSE_OPTS__cur_arg}"}\"" || return 1
      shift 2; continue


    elif printf "%s" "${_PARSE_OPTS__long_list_flags}" \
        | grep -q -- "${_PARSE_OPTS__cur_arg}" >/dev/null 2>/dev/null
    then
      # long - flag
      eval "PARSE_OPTS__opt$(printf '%s' "${_PARSE_OPTS__cur_arg}" | tr '-' '_')"="\"1\"" || return 1
      shift; continue


    elif printf "%s" "${_PARSE_OPTS__long_list_args}" \
        | grep -q -- "${_PARSE_OPTS__cur_arg}" >/dev/null 2>/dev/null
    then
      # long - arg
      eval "PARSE_OPTS__opt$(printf '%s' "${_PARSE_OPTS__cur_arg}" | tr '-' '_')"="\"${2?No argument passed for the option "${_PARSE_OPTS__cur_arg}"}\"" || return 1
      shift 2; continue


    else
      # unexpected token
      printf " * Invalid token '%s'\n" "${_PARSE_OPTS__cur_arg}" >&2
      return 1


    fi
  done
  return 0
}



# get variable value if exists,
#   or default value (postfixed with "__DEFAULT") if empty
# args: <varname>
get_var_default() {
  _GET_VAR_DEFAULT__varname="${1:?varname}"
  _GET_VAR_DEFAULT__value="$(\
    eval "printf \"%s\" \"\${${_GET_VAR_DEFAULT__varname}:-\${${_GET_VAR_DEFAULT__varname}__DEFAULT}}\"")"
  _GET_VAR_DEFAULT__default_cmd="$(\
    eval "printf \"%s\" \"\${${_GET_VAR_DEFAULT__varname}__DEFAULT_CMD}\"")"

  if [ -z "${_GET_VAR_DEFAULT__value}" ] && [ -n "${_GET_VAR_DEFAULT__default_cmd}" ]
  then
    # if value is empty and default command exists
    eval "${_GET_VAR_DEFAULT__default_cmd}"
  else
    printf "%s" "${_GET_VAR_DEFAULT__value}"
  fi
}



# print label of given variable name.
# '(given-varname)__LABEL' variable should exists.
# args: <varname>
get_var_label() {
  _GET_VAR_LABEL__varname="${1:?varname}"
  eval "printf \"%s\" \"\${${_GET_VAR_LABEL__varname}__LABEL}\""
}



# print actual value (currently applied) of given variable name.
# '(given-varname)__CURFILE' variable should exists.
# args: <uid> <varname>
get_var_actual() {
  _GET_VAR_ACTUAL__uid="${1:?uid}"
  _GET_VAR_ACTUAL__varname="${2:?varname}"

  _GET_VAR_ACTUAL__curfile="$(eval "printf \"%s\" \"\${${_GET_VAR_ACTUAL__varname}__CURFILE}\"")"
  _GET_VAR_ACTUAL__curfile_dir="/sys/fs/cgroup/user.slice/user-${_GET_VAR_ACTUAL__uid}.slice/"
  _GET_VAR_ACTUAL__value="$(\
    [ -r "${_GET_VAR_ACTUAL__curfile_dir}/${_GET_VAR_ACTUAL__curfile}" ] \
      && cat "${_GET_VAR_ACTUAL__curfile_dir}/${_GET_VAR_ACTUAL__curfile}" 2>/dev/null)"

  if [ "${_GET_VAR_ACTUAL__value}" -gt 1048576 ] 2>/dev/null \
       && command -v numfmt >/dev/null 2>/dev/null
  then
    printf "%s" "${_GET_VAR_ACTUAL__value}" | numfmt --to=iec-i
  else
    printf "%s" "${_GET_VAR_ACTUAL__value}"
  fi
}



# search usable uid
# no arg
search_empty_user_id() {
  if ! [ "${UID_LOWER_LIMIT_INC}" -lt "${UID_UPPER_LIMIT_EXC}" ]
  then
    abort "Invalid UID range variables"
  fi
  _SEARCH_EMPTY_USER_ID__cur_id="${UID_LOWER_LIMIT_INC}"

  while \
    getent passwd "${_SEARCH_EMPTY_USER_ID__cur_id}" \
           >/dev/null 2>/dev/null \
      || getent group "${_SEARCH_EMPTY_USER_ID__cur_id}" \
                >/dev/null 2>/dev/null
  do
    _SEARCH_EMPTY_USER_ID__cur_id="
$(( _SEARCH_EMPTY_USER_ID__cur_id + 1 ))"
    if ! [ "${_SEARCH_EMPTY_USER_ID__cur_id}" \
             -lt "${UID_UPPER_LIMIT_EXC}" ]
    then
      abort "No usable UID and GID found in the given range"\
            " '[${UID_LOWER_LIMIT_INC}, ${UID_UPPER_LIMIT_EXC})'"
    fi
    true
  done

  printf "%s" "$(( _SEARCH_EMPTY_USER_ID__cur_id ))"
}



# get systemd cgroup slice data
# args: <uid> <key>
get_rc() {
  _GET_RC__uid="${1:?UID}"
  _GET_RC__k="${2:?key}"

  _GET_RC__dir="${SYSTEMD_RC_PREFIX_FULL}${_GET_RC__uid}${SYSTEMD_RC_POSTFIX_DIR}"
  _GET_RC__file="${SYSTEMD_RC_CONF_PREFIX}${_GET_RC__k}${SYSTEMD_RC_CONF_POSTFIX}"

  [ -r "${_GET_RC__dir}/${_GET_RC__file}" ] \
    && grep "^${_GET_RC__k}=" "${_GET_RC__dir}/${_GET_RC__file}" \
      | cut -d= -f2-
}



# set systemd cgroup slice. removed if val is null
# args: <uid> <key> [val]
set_rc() {
  _SET_RC__uid="${1:?UID}"
  _SET_RC__k="${2:?key}"
  _SET_RC__v="${3}"

  _SET_RC__dir="${SYSTEMD_RC_PREFIX_FULL}${_SET_RC__uid}${SYSTEMD_RC_POSTFIX_DIR}"
  _SET_RC__file="${SYSTEMD_RC_CONF_PREFIX}${_SET_RC__k}${SYSTEMD_RC_CONF_POSTFIX}"

  if [ -n "${_SET_RC__v}" ]
  then
    # set
    printf " - Setting systemd user slice param [%s] to [%s] ...\n" \
           "${_SET_RC__k}" "${_SET_RC__v}"
    [ ! -e "${_SET_RC__dir}" ] && sudo mkdir -p "${_SET_RC__dir}"
    printf "%s\n[Slice]\n%s=%s\n" \
           "${SAMAN_AUTOGEN_COMMENT}" \
           "${_SET_RC__k}" "${_SET_RC__v}" \
      | sudo tee "${_SET_RC__dir}/${_SET_RC__file}" \
             >/dev/null
    _SET_RC__exit_code="${?}"
  else
    # remove
    [ ! -e "${_SET_RC__dir}/${_SET_RC__file}" ] && return 0
    printf " - Removing systemd user slice param [%s]...\n" \
           "${_SET_RC__k}"
    sudo rm -f "${_SET_RC__dir}/${_SET_RC__file}"
    _SET_RC__exit_code="${?}"
    [ "$(find "${_SET_RC__dir}" -type f 2>/dev/null | wc -l || printf "0")" -eq "0" ] \
      && sudo rm -rf "${_SET_RC__dir}"
  fi
  return "${_SET_RC__exit_code}"
}





