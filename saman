# print help string
# no arg
print_help() {
  printf "%susage: %s <MODE> [args...]%s

  <MODE>
   - %sadd%s:     create a new SAMAN service account
                 $ %s add <account-name> [port-1] [port-2] ...
   - %sls%s:      list all SAMAN service accounts
                 $ %s ls
   - %sdetail%s:  print details of an SAMAN service account
                 $ %s detail <account-name>
   - %srm%s:      remove an SAMAN service account
                 $ %s rm <account-name> [force]
   - %shelp%s:    print help message
                 $ %s help
  
" \
         "${C_ACCENT_FG}" "${BIN_BASENAME}" "${C_RESET}" \
         "${C_ACCENT_FG}" "${C_RESET}" "${BIN_BASENAME}" \
         "${C_ACCENT_FG}" "${C_RESET}" "${BIN_BASENAME}" \
         "${C_ACCENT_FG}" "${C_RESET}" "${BIN_BASENAME}" \
         "${C_ACCENT_FG}" "${C_RESET}" "${BIN_BASENAME}" \
         "${C_ACCENT_FG}" "${C_RESET}" "${BIN_BASENAME}"
}
HELP_STR="$(print_help)"



# print error message
# args: <error-msg>
print_err() {
  _PRINT_ERR__msg="${1:?msg}"

  printf "%s: %s%s%s\n" \
         "${BIN_BASENAME}" \
         "${C_WARN_FG}" "${_PRINT_ERR__msg}" "${C_RESET}" \
         >&2
}



# print error message then exit
# args: <error-msg> [exit-code]
abort() {
  _ABORT__msg="${1:?msg}"
  _ABORT__exitcode="${2}"

  print_err "${_ABORT__msg}"
  exit "${_ABORT__exitcode:-1}"
}



# print error message with help string then exit
# args: <error-msg> [exit-code]
abort_help() {
  _ABORT_HELP__msg="${1:?msg}"
  _ABORT_HELP__exitcode="${2}"


  abort "${_ABORT_HELP__msg}

${C_RESET}${HELP_STR}" "${_ABORT_HELP__exitcode}"
}



# read string from user
# args: <message> <var-name>
read_normal() {
  _READ_NORMAL__msg="${1:?msg}"
  _READ_NORMAL__name="${2:?name}"

  trap 'printf "${C_RESET} \n"; return 1' TERM HUP INT
  printf " + %s:%s " "${_READ_NORMAL__msg}" "${C_RESET}${C_WARN_FG}"
  read -r "${_READ_NORMAL__name?}"
  _READ_NORMAL__ret_val="${?}"
  trap - TERM HUP INT
  printf "%s\n" "${C_RESET}"

  return "${_READ_NORMAL__ret_val}"
}



# set colors
# no arg
set_colors() {
  unset C_ACCENT_FG C_ACCENT_BG C_WARN_FG C_WARN_BG C_RESET
  if [ -t 1 ]
  then
    C_ACCENT_FG="$(tput setaf 2 2>/dev/null)"
    C_ACCENT_BG="$(tput setaf 0 2>/dev/null)$(tput setab 2 2>/dev/null)"
    C_WARN_FG="$(tput setaf 1 2>/dev/null)"
    C_WARN_BG="$(tput setaf 0 2>/dev/null)$(tput setab 1 2>/dev/null)"
    C_RESET="$(tput sgr0 2>/dev/null)$(tput el 2>/dev/null)"
  fi
}





