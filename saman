#!/bin/sh

#==========================================================#
#          Linux Service Account Manager (SAMAN)           #
#                                                    v1.3  #
#==========================================================#
#                                                          #
#  Make a new linux account and do followings:             #
#                                                          #
#  - enable linger:                                        #
#      enable the user session to use user systemd         #
#  - export XDG_RUNTIME_DIR:                               #
#      define required env var to manage user systemd      #
#  - open firewalld (optional):                            #
#      open specified tcp/udp ports on firewalld           #
#                                                          #
#==========================================================#
#      Author: Kim Hwiwon < kim.hwiwon@outlook.com >       #
#==========================================================#

#
# usage: saman <MODE> [args...]
#
#  <MODE>
#   - add:     create a new SAMAN service account
#                 $ saman add <account-name> [port-1] [port-2] ...
#   - ls:      list all SAMAN service accounts
#                 $ saman ls
#   - detail:  print details of an SAMAN service account
#                 $ saman detail <account-name>
#   - rm:      remove an SAMAN service account
#                 $ saman rm <account-name> [force]
#   - help:    print help message
#                 $ saman help
#





#==========================================================#
#                       environments                       #
#==========================================================#

########## envs ##########
# configurable
UID_LOWER_LIMIT_INC="${UID_LOWER_LIMIT_INC:-50000}"
UID_UPPER_LIMIT_EXC="${UID_UPPER_LIMIT_EXC:-60000}"
# fixed
BIN_BASENAME="$(basename "${0}")"
ACC_HOME_BASEDIR="/opt/saman"
SAMAN_FILE_PREFIX="SAMAN"     # no dash ('-')
SAMAN_ACC_COMMENT_PREFIX="[SAMAN]" # no space (' ')
SAMAN_AUTOGEN_COMMENT="# Auto-generated by SAMAN: DO NOT EDIT"
# etc
SYSTEMD_ROOT="/etc/systemd/system"
SYSTEMD_RC_PREFIX="user-"
SYSTEMD_RC_PREFIX_FULL="${SYSTEMD_ROOT}/${SYSTEMD_RC_PREFIX}"
SYSTEMD_RC_POSTFIX=".slice"
SYSTEMD_RC_POSTFIX_DIR="${SYSTEMD_RC_POSTFIX}.d"
SYSTEMD_RC_CONF_PREFIX="${SAMAN_FILE_PREFIX}-"
SYSTEMD_RC_CONF_POSTFIX=".conf"





#==========================================================#
#              systemd resource control vars               #
#==========================================================#


########## systemd RC accountings ##########
USER_CPU__LABEL="CPUAccounting"
USER_MEM__LABEL="MemoryAccounting"
USER_TASKS__LABEL="TasksAccounting"
USER_IO__LABEL="IOAccounting"
USER_NETWORK__LABEL="IPAccounting"


########## systemd resource control consts keys ##########
USER_SOCK_DENY__LABEL="SocketBindDeny"
USER_DEV_POLICY__LABEL="DevicePolicy"
USER_OOM_SWAP__LABEL="ManagedOOMSwap"
USER_OOM_MEM_PRESSURE__LABEL="ManagedOOMMemoryPressure"

# default values
USER_SOCK_DENY__DEFAULT="any"
USER_DEV_POLICY__DEFAULT="closed"
USER_OOM_SWAP__DEFAULT="kill"
USER_OOM_MEM_PRESSURE__DEFAULT="kill"


########## systemd resource control configurable keys ##########
USER_CPU_WEIGHT__LABEL="CPUWeight"
USER_CPU_QUOTA__LABEL="CPUQuota"
USER_MEM_MAX__LABEL="MemoryMax"
USER_MEM_HIGH__LABEL="MemoryHigh"
USER_SWAP_MAX__LABEL="MemorySwapMax"
USER_ZSWAP_MAX__LABEL="MemoryZSwapMax"
USER_TASKS_MAX__LABEL="TasksMax"
USER_IO_WEIGHT__LABEL="IOWeight"
USER_DEV_ALLOW__LABEL="DeviceAllow"
USER_SOCK_ALLOW__LABEL="SocketBindAllow"

USER_CPU_WEIGHT__CURFILE="cpu.weight"
USER_CPU_QUOTA__CURFILE="cpu.max"
USER_MEM_MAX__CURFILE="memory.max"
USER_MEM_HIGH__CURFILE="memory.high"
USER_SWAP_MAX__CURFILE="memory.swap.max"
USER_ZSWAP_MAX__CURFILE="memory.zswap.max"
USER_TASKS_MAX__CURFILE="pids.max"
USER_IO_WEIGHT__CURFILE="io.bfq.weight"

# default values
USER_CPU_WEIGHT__DEFAULT="20"
USER_CPU_QUOTA__DEFAULT=""
USER_MEM_MAX__DEFAULT="50%"
USER_MEM_HIGH__DEFAULT=""
USER_SWAP_MAX__DEFAULT="0"
USER_ZSWAP_MAX__DEFAULT="0"
USER_TASKS_MAX__DEFAULT="100"
USER_IO_WEIGHT__DEFAULT="20"
USER_DEV_ALLOW__DEFAULT=""
USER_SOCK_ALLOW__DEFAULT=""

# default command
USER_MEM_HIGH__DEFAULT_CMD='
__USER_MEM_HIGH__DEFAULT_CMD__mem_max="$(get_var_default "USER_MEM_MAX")";
__USER_MEM_HIGH__DEFAULT_CMD__mem_max_n="${__USER_MEM_HIGH__DEFAULT_CMD__mem_max%%[^[:digit:]]*}";
printf "%s%s" "$((__USER_MEM_HIGH__DEFAULT_CMD__mem_max_n * 9 / 10))" "${__USER_MEM_HIGH__DEFAULT_CMD__mem_max#${__USER_MEM_HIGH__DEFAULT_CMD__mem_max_n}}";'


########## var list for dynamic var read ##########
# all rc configurable key list
SYSTEMD_RC_LIST="USER_CPU_WEIGHT USER_CPU_QUOTA USER_MEM_MAX \
                 USER_MEM_HIGH USER_SWAP_MAX USER_ZSWAP_MAX  \
                 USER_TASKS_MAX USER_IO_WEIGHT USER_DEV_ALLOW USER_SOCK_ALLOW"
# all rc accounting list
SYSTEMD_RC_ACCOUNTING_LIST="USER_CPU USER_MEM USER_TASKS \
                            USER_IO USER_NETWORK"
# all rc const key list
SYSTEMD_RC_CONST_LIST="USER_SOCK_DENY USER_DEV_POLICY \
                       USER_OOM_SWAP USER_OOM_MEM_PRESSURE"






#==========================================================#
#                       main routine                       #
#==========================================================#



# main function - choose mode
# args: full argument list of the current command
main() {
  set_colors

  # script mode
  _MODE="${1}"
  if [ "$#" -gt 0 ]; then shift 2>/dev/null; fi

  case "${_MODE}" in
    "add")
      mode_add "${@}"
      ;;

    "ls")
      mode_ls "${@}"
      ;;

    "detail")
      mode_detail "${@}"
      ;;

    "rm")
      mode_rm "${@}"
      ;;

    "help")
      printf "%s\n" "${HELP_STR}"
      ;;

    *)
      abort_help "Pass a job to do: [ add / ls / detail / rm / help ]"
      ;;
  esac
}



# [add] mode
# args: <acc-name> [svc-port-1] [svc-port-2] ...
mode_add() {
  # parse all opts and args
  parse_opts "${BIN_BASENAME}" "c:C:m:M:s:z:t:i:d:p:" "cpu-weight:,cpu-quota:,memory-max:,memory-high:,swap-max:,zswap-max:,tasks-max:,io-weight:,dev-allow:,sock-allow:" "${@}" \
    && eval set -- "${PARSE_OPTS__args}" || return 1
  set | grep -v "^C_"

  # linux account name
  _MODE_ADD__acc_name="${1}"
  if [ -z "${_MODE_ADD__acc_name}" ]; \
    then abort_help "Missing linux user account name"; fi
  if getent passwd "${_MODE_ADD__acc_name}" >/dev/null 2>/dev/null; \
    then abort "Linux user '${_MODE_ADD__acc_name}' already exists"; fi
  if getent group "${_MODE_ADD__acc_name}" >/dev/null 2>/dev/null; \
    then abort "Linux user group '${_MODE_ADD__acc_name}' already exists"; fi

  _MODE_ADD__acc_home="${ACC_HOME_BASEDIR}/${_MODE_ADD__acc_name}"
  if [ -e "${_MODE_ADD__acc_home}" ]; \
    then abort "Home directory '${_MODE_ADD__acc_home}' already exists"; fi

  _MODE_ADD__acc_id="$(search_empty_user_id)" || exit 1

  _MODE_ADD__firewalld_svc_name="${SAMAN_FILE_PREFIX}-${_MODE_ADD__acc_name}"

  shift 2>/dev/null


  test_root_permission

  # add all data
  new_acc_rc "${_MODE_ADD__acc_id}" || {
    rm_acc_rc "${_MODE_ADD__acc_id}" >/dev/null
    abort "Failed to create new resource control configs"
  }

  new_svc_acc "${_MODE_ADD__acc_name}" "${_MODE_ADD__acc_home}" "${_MODE_ADD__acc_id}" \
    || {
    rm_svc_acc "${_MODE_ADD__acc_name}" >/dev/null
    rm_acc_rc "${_MODE_ADD__acc_id}" >/dev/null
    abort "Failed to create a new service account"
  }

  if [ "$#" -gt 0 ] && command -v firewall-cmd >/dev/null
  then
    new_firewall_svc "${_MODE_ADD__firewalld_svc_name}" \
      || {
      rm_firewall_svc "${_MODE_ADD__firewalld_svc_name}" >/dev/null
      rm_svc_acc "${_MODE_ADD__acc_name}" >/dev/null
      rm_acc_rc "${_MODE_ADD__acc_id}" >/dev/null
      abort "Failed to create a new firewalld service"
    }
  fi


  # print info
  mode_detail "${_MODE_ADD__acc_name}"
}



# [ls] mode
# no arg
mode_ls() {
  # parse all opts and args
  parse_opts "${BIN_BASENAME}" "" "" "${@}" && eval set -- "${PARSE_OPTS__args}" || return 1


  _MODE_LS__acc_passwd_ent="$(getent passwd)"
  _MODE_LS__sed_args="$(printf "%s" "${_MODE_LS__acc_passwd_ent}" | cut -d: -f5 \
               | cut -d' ' -f1 \
               | grep -Fxn "${SAMAN_ACC_COMMENT_PREFIX}" | cut -d: -f1 \
               | xargs printf "-e %sp ")"
  if [ -n "${_MODE_LS__sed_args}" ] && [ "${_MODE_LS__sed_args}" != "-e p " ]
  then
    _MODE_LS__acc_list="$(printf "%s" "${_MODE_LS__acc_passwd_ent}" \
                 | sed -n ${_MODE_LS__sed_args} 2>/dev/null | cut -d: -f1 \
                 | tr '\n' '\t')" \
      || return 1
    if [ -n "${_MODE_LS__acc_list}" ]
    then
      _MODE_LS__acc_list="$(printf "%s%s%s" \
                          "${C_ACCENT_BG}" "${_MODE_LS__acc_list}" "${C_RESET}" \
                   | sed "s/\t/${C_RESET}\t${C_ACCENT_BG}/g")"
    fi
  fi
  printf "\n%s\n\n" \
         "${_MODE_LS__acc_list:-(** No SAMAN service account exists **)}"
}



# [detail] mode
# args: <acc-name>
mode_detail() {
  # parse all opts and args
  parse_opts "${BIN_BASENAME}" "" "" "${@}" && eval set -- "${PARSE_OPTS__args}" || return 1


  _MODE_DETAIL__acc_name="${1}"
  if [ -z "${_MODE_DETAIL__acc_name}" ]; \
    then abort_help "Missing linux user account name"; fi
  if ! _MODE_DETAIL__acc_passwd_ent="$(getent passwd "${_MODE_DETAIL__acc_name}")" \
       >/dev/null 2>/dev/null; \
    then abort "No linux user '${_MODE_DETAIL__acc_name}' found"; fi
  if ! printf "%s" "${_MODE_DETAIL__acc_passwd_ent}" | cut -d: -f5 \
      | cut -d' ' -f1 \
      | grep -Fx "${SAMAN_ACC_COMMENT_PREFIX}" >/dev/null 2>/dev/null
  then abort "Linux user '${_MODE_DETAIL__acc_name}' is not an SAMAN account"; fi


  _MODE_DETAIL__acc_uid="$(printf "%s" "${_MODE_DETAIL__acc_passwd_ent}" | cut -d: -f3)"
  _MODE_DETAIL__acc_gid="$(printf "%s" "${_MODE_DETAIL__acc_passwd_ent}" | cut -d: -f4)"
  _MODE_DETAIL__acc_home="$(printf "%s" "${_MODE_DETAIL__acc_passwd_ent}" | cut -d: -f6)"

  # get all configurable rc configs
  unset _MODE_DETAIL__rc_detail_str
  for _MODE_DETAIL__k_varname in ${SYSTEMD_RC_LIST}
  do
    _MODE_DETAIL__k="$(get_var_label "${_MODE_DETAIL__k_varname}")"
    _MODE_DETAIL__v="$(get_rc "${_MODE_DETAIL__acc_uid}" "${_MODE_DETAIL__k}")"
    _MODE_DETAIL__v_current="$(get_var_actual "${_MODE_DETAIL__acc_uid}" \
                                              "${_MODE_DETAIL__k_varname}")"

    _MODE_DETAIL__rc_detail_str="$(printf "%s\n   *  %-20s %s%-15s %s%s" \
                                          "${_MODE_DETAIL__rc_detail_str}" \
                                          "${_MODE_DETAIL__k}" \
                                          "${_MODE_DETAIL__v:+${C_ACCENT_FG}}" \
                                          "${_MODE_DETAIL__v:-(none)}" \
                                          "${_MODE_DETAIL__v_current}" \
                                          "${C_RESET}" \
                                          )"
  done

  printf "
Username: %s%s%s
UID/GID:  %s%s%s:%s%s%s
Home:     %s%s%s
Resource-Limits ('%s'):
      %-20s %-15s %s %s
\n" \
         "${C_ACCENT_FG}" "${_MODE_DETAIL__acc_name}" "${C_RESET}" \
         "${C_ACCENT_FG}" "${_MODE_DETAIL__acc_uid}" "${C_RESET}" \
         "${C_ACCENT_FG}" "${_MODE_DETAIL__acc_gid}" "${C_RESET}" \
         "${C_ACCENT_FG}" "${_MODE_DETAIL__acc_home}" "${C_RESET}" \
         "${SYSTEMD_RC_PREFIX}${_MODE_DETAIL__acc_uid}${SYSTEMD_RC_POSTFIX}" \
         "<key>" "<value>" "<cgroup-value>" \
         "${_MODE_DETAIL__rc_detail_str}"
}



# [rm] mode
# args: <acc-name> [-f]
mode_rm() {
  # parse all opts and args
  parse_opts "${BIN_BASENAME}" "f" "force" "${@}" && eval set -- "${PARSE_OPTS__args}" || return 1


  # linux account name
  _MODE_RM__acc_name="${1}"
  if [ -z "${_MODE_RM__acc_name}" ]; \
    then abort_help "Missing linux user account name"; fi
  if ! _MODE_RM__acc_passwd_ent="$(getent passwd "${_MODE_RM__acc_name}")" \
       >/dev/null 2>/dev/null; \
    then abort "No linux user '${_MODE_RM__acc_name}' found"; fi
  if ! printf "%s" "${_MODE_RM__acc_passwd_ent}" \
      | cut -d: -f5 | grep -F "${SAMAN_ACC_COMMENT_PREFIX}" \
                           >/dev/null 2>/dev/null
  then abort "Linux user '${_MODE_RM__acc_name}' is not an SAMAN account"; fi
  _MODE_RM__acc_uid="$(printf "%s" "${_MODE_RM__acc_passwd_ent}" | cut -d: -f3)"

  _MODE_RM__firewalld_svc_name="${SAMAN_FILE_PREFIX}-${_MODE_RM__acc_name}"


  test_root_permission

  # prompt once before remove if interactive shell
  if [ -t 1 ] && { [ -z "${PARSE_OPTS__opt_f}" ] && [ -z "${PARSE_OPTS__opt__force}" ] ; }
  then
    _MODE_RM__prompt="value_to_start_loop"
    until [ "${_MODE_RM__prompt}" = "y" ] || [ "${_MODE_RM__prompt}" = "Y" ] \
            || [ "${_MODE_RM__prompt}" = "n" ] || [ "${_MODE_RM__prompt}" = "N" ] \
            || [ -z "${_MODE_RM__prompt}" ]; do
      read_normal " ${C_WARN_BG}[!!! WARNING !!!]${C_RESET} This process will ${C_WARN_FG}REMOVE ALL DATA${C_RESET} of the user '${C_ACCENT_FG}${_MODE_RM__acc_name}${C_RESET}'.
    Proceed? [${C_WARN_FG}y${C_RESET}/N]" _MODE_RM__prompt || return 1
    done
    if [ "${_MODE_RM__prompt}" != "y" ] && [ "${_MODE_RM__prompt}" != "Y" ]; \
      then exit 1; fi
  fi



  # remove all data
  rm_svc_acc "${_MODE_RM__acc_name}" \
    || abort "Failed to remove the existing account"

  rm_acc_rc "${_MODE_RM__acc_uid}" \
    || abort "Failed to remove existing resource control configs"

  if command -v firewall-cmd >/dev/null \
      && sudo firewall-cmd --get-services \
        | grep "${_MODE_RM__firewalld_svc_name}" >/dev/null 2>/dev/null \
      && sudo firewall-cmd --info-service="${_MODE_RM__firewalld_svc_name}" \
              >/dev/null 2>/dev/null
  then
    rm_firewall_svc "${_MODE_RM__firewalld_svc_name}" \
      || abort "Failed to remove the existing firewalld service"
  fi
}





